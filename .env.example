# PostgreSQL
POSTGRES_USER=praktikum
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=ohukvaliteet
DB_PORT_HOST=55432

# Streamlit dashboard
DASHBOARD_PORT_HOST=8501
DASHBOARD_AUTOREFRESH_SECONDS=30

# Pipeline (ETL) seaded
# Mitme päeva tagant ohuseire/openmeteo andmeid laadida (max 92)
LOAD_DAYS=7
# Komaeraldatud jaamade airviro koodid, mida soovid laadida
# S00=Liivalaia, S01=Rahu, S05=Õismäe
STATIONS=S05
# Komaeraldatud näitajate koodid
INDICATORS=PM25,PM10,NO2,SO2,O3

# Scheduler (cron)
PIPELINE_CRON=0 * * * *
RUN_ON_STARTUP=true