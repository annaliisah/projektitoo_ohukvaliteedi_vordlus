# PostgreSQL
POSTGRES_USER=praktikum
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=ohukvaliteet
DB_PORT_HOST=55432

# Streamlit dashboard
DASHBOARD_PORT_HOST=8501

# Pipeline ETL seaded
# Mitme päeva tagant andmeid laadida (Open-Meteo lubab kuni 92 päeva ajalugu)
LOAD_DAYS=7

# Komaeraldatud jaamade airviro koodid (S00=Liivalaia, S01=Rahu, S05=Õismäe)
STATIONS=S05

# Komaeraldatud ohuseire indikaatorite ID-d
# 1=SO2, 3=NO2, 6=O3, 21=PM10, 23=PM2.5
INDICATOR_IDS=1,3,6,21,23

# Scheduler (cron) - käivitub iga tund
PIPELINE_CRON=0 * * * *
RUN_ON_STARTUP=true